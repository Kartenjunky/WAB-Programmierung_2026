    <bpmn:serviceTask id="PruefeDaten" name="PruefeKunde" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=&#34;https://brookless-highly-melody.ngrok-free.dev/customers/&#34; + string(customerID)" target="url" />
          <zeebe:input source="={&#10;  Accept: &#34;application/json&#34;&#10;}" target="headers" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  customerValid: response.body.valid,&#10;  checkedCustomerId: response.body.id,&#10;  customerName: response.body.name,&#10;  customerEmail: response.body.email,&#10;  customerHttpStatus: response.status&#10;}" />
          <zeebe:header key="errorExpression" value="=if matches(error.code, &#34;404&#34;)&#10;then bpmnError(&#34;CUSTOMER_NOT_FOUND&#34;, &#34;Customer nicht vorhanden&#34;, error.variables.response.body)&#10;else null" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_194x8i4</bpmn:incoming>
      <bpmn:outgoing>Flow_0am6cqu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="succsess" name="Succsess" sourceRef="Gateway_12kcy3y" targetRef="EndEvent_TicketDone">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=orderHttpStatus = 200</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="TicketAnlage" name="Ticket Anlage" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="POST" target="method" />
          <zeebe:input source="https://brookless-highly-melody.ngrok-free.dev/orders" target="url" />
          <zeebe:input source="={&#10;  Content-Type: &#34;application/json&#34;,&#10;  Accept: &#34;application/json&#34;&#10;}" target="headers" />
          <zeebe:input source="=true" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="={&#10;  product: product,&#10;  quantity: quantity&#10;}" target="body" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  orderId: response.body.orderId,&#10;  orderStatus: response.body.status,&#10;  orderedProduct: response.body.product,&#10;  orderedQuantity: response.body.quantity,&#10;  orderHttpStatus: response.status&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0bl6nkm</bpmn:incoming>
      <bpmn:outgoing>Flow_0jyqs25</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_TicketDone" name="Ticket Done">
      <bpmn:incoming>succsess</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:startEvent id="StartEvent_TicketEingang" name="Ticket Eingang">
      <bpmn:outgoing>Flow_194x8i4</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="ticketFehler" name="Ticket Fehler">
      <bpmn:incoming>fail</bpmn:incoming>
      <bpmn:incoming>Flow_14rcmc9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0bl6nkm" name="true" sourceRef="Gateway_0np105n" targetRef="TicketAnlage">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=customerValid = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
