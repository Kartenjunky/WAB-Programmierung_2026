    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="fail" name="Fail" sourceRef="Gateway_12kcy3y" targetRef="ticketFehler">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=orderHttpStatus != 201</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_14rcmc9" name="false" sourceRef="Gateway_0np105n" targetRef="ticketFehler">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=customerValid = false</bpmn:conditionExpression>
